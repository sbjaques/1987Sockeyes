{
  "name": "1987-sockeyes",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run build:image-index && vite --mode public",
    "dev:private": "npm run build:image-index && vite --mode private",
    "build:image-index": "node scripts/build-image-index.mjs",
    "prebuild": "npm run build:image-index",
    "build": "npm run build:public",
    "build:public": "tsc -b && vite build --mode public",
    "build:private": "tsc -b && vite build --mode private",
    "build:all": "npm run build:public && npm run build:private",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "validate:data": "node scripts/validate-data.mjs"
  },
  "dependencies": {
    "fuse.js": "^7.3.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-helmet-async": "^3.0.0",
    "react-markdown": "^9.1.0",
    "react-router-dom": "^7.14.0",
    "remark-gfm": "^4.0.1",
    "yet-another-react-lightbox": "^3.31.0"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.91.0",
    "@aws-sdk/client-s3": "^3.1036.0",
    "@eslint/js": "^9.39.4",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.2",
    "playwright": "^1.59.1",
    "postcss": "^8.5.9",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.19",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "vitest": "^3.2.4"
  }
}
